# Copy this to .env and fill in your values
# NEVER commit .env to git

# Required: Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Optional: Restrict draft commands to specific channels (comma-separated channel IDs)
# Right-click a channel in Discord (with Developer Mode on) → Copy Channel ID
# Example: DRAFT_CHANNEL_IDS=123456789,987654321
DRAFT_CHANNEL_IDS=
